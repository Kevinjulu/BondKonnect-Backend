APP_NAME=BondKonnect
APP_ENV=${APP_ENV:-production}
APP_KEY=base64:NjjM8rIH3Dl4xpfgFHxczIkhpDhnWjYAejwwqRNRBj0=
APP_DEBUG=${APP_DEBUG:-false}
APP_URL=https://${RAILWAY_PUBLIC_DOMAIN:-localhost:8000}

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Primary Database (Railway provides DATABASE_URL, PGHOST, etc. automatically)
DB_CONNECTION=pgsql
DB_HOST=${PGHOST:-127.0.0.1}
DB_PORT=${PGPORT:-5432}
DB_DATABASE=${PGDATABASE:-neondb}
DB_USERNAME=${PGUSER:-neondb_owner}
DB_PASSWORD=${PGPASSWORD:-}
DB_SSLMODE=require
DATABASE_URL=${DATABASE_URL:-}

# Legacy/Secondary Connection Variables
BK_API_DB_DRIVER=pgsql
BK_DB_DRIVER=pgsql
BK_HOST=${PGHOST:-127.0.0.1}
BK_PORT=${PGPORT:-5432}
BK_DATABASE=${PGDATABASE:-neondb}
BK_USERNAME=${PGUSER:-neondb_owner}
BK_PASSWORD=${PGPASSWORD:-}
BK_API_DB_SSLMODE=require
BK_DB_SSLMODE=require

# Primary Redis (Railway Redis)
REDIS_CLIENT=phpredis
REDIS_HOST=${REDISHOST:-127.0.0.1}
REDIS_PORT=${REDISPORT:-6379}
REDIS_PASSWORD=${REDISPASSWORD:-}

# Laravel Service Drivers
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

MEMCACHED_HOST=127.0.0.1

FILESYSTEM_DISK=local

# Broadcaster (Pusher)
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=2117080
PUSHER_APP_KEY=8b6fde671de8467f0bd2
PUSHER_APP_SECRET=0776b2d0bdb50b518e86
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=eu
PUSHER_API=xQKY7cn-7wIxM5hhyovkAogClOJYVDxZk6WGqbrxJss

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# CORS and Sanctum Configuration (Allowed Origins already regex-supported in config/cors.php)
CORS_ALLOWED_ORIGIN=
SANCTUM_STATEFUL_DOMAINS=localhost:4000,127.0.0.1:4000
SESSION_DOMAIN=
CORS_SUPPORTS_CREDENTIALS=true
