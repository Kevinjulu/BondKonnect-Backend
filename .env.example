APP_NAME=BondKonnect
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password
DATABASE_URL=

BK_DB_DRIVER=pgsql
BK_API_DB_DRIVER=pgsql

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=your-pusher-app-id
PUSHER_APP_KEY=your-pusher-app-key
PUSHER_APP_SECRET=your-pusher-app-secret
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=eu
PUSHER_API=

MAIL_MAILER=resend
RESEND_API_KEY=your-resend-api-key
MAIL_FROM_ADDRESS_PROD=no-reply@bondkonnect.com
MAIL_FROM_NAME_PROD=BondKonnect
MAIL_FROM_ADDRESS=no-reply@bondkonnect.com
MAIL_FROM_NAME=BondKonnect

# CORS / Sanctum — local development defaults
CORS_ALLOWED_ORIGIN=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost
SESSION_DOMAIN=localhost
CORS_SUPPORTS_CREDENTIALS=true

# ── Railway production overrides ─────────────────────────────────────────────
# Uncomment and set these in Railway's variable panel (not in this file).
# FRONTEND_URL=https://bondkonnect.up.railway.app
# APP_URL=https://laravel-backend-api.up.railway.app
# CORS_ALLOWED_ORIGINS=https://bondkonnect.up.railway.app,https://laravel-backend-api.up.railway.app
# SANCTUM_STATEFUL_DOMAINS=bondkonnect.up.railway.app,laravel-backend-api.up.railway.app
# SESSION_DOMAIN=.up.railway.app
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none
