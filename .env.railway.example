# Example env file for Railway deployment (DO NOT COMMIT SECRETS)
# Copy values from Railway to the Railway Environment variables dashboard.

# Application
APP_NAME=BondKonnect
APP_ENV=production
APP_DEBUG=false
APP_KEY=change-me-generated-locally
APP_URL=https://your-backend.up.railway.app

# Database - Railway provides `DATABASE_URL` (Postgres)
DB_CONNECTION=pgsql
DATABASE_URL=postgresql://<PGUSER>:<POSTGRES_PASSWORD>@<RAILWAY_PRIVATE_DOMAIN>:5432/<PGDATABASE>

# Optional explicit PG vars (Railway populates these too)
PGHOST=<RAILWAY_PRIVATE_DOMAIN>
PGPORT=5432
PGDATABASE=<PGDATABASE>
PGUSER=<PGUSER>
PGPASSWORD=<POSTGRES_PASSWORD>

# Redis (if using Railway Redis addon)
REDIS_URL=

# Mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com

# CORS
# Set to your frontend's production URL (Vercel)
CORS_ALLOWED_ORIGIN=https://bond-konnect-web.vercel.app/
CORS_SUPPORTS_CREDENTIALS=false

# Queue
QUEUE_CONNECTION=database

# Notes:
# - Replace angled placeholders (<...>) with Railway-provided values or the
#   exact DATABASE_URL that Railway gives you. Do not commit this file with
#   real secrets. Use Railway's Environment variables UI to store secrets.
